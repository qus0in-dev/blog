{
  "name": "qus0in-dev-blog",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "generate:og": "node scripts/generate-og.mjs",
    "build": "pnpm run generate:og && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "commit:check": "if git diff --cached --quiet; then echo 'No staged changes.'; exit 1; fi",
    "commit:msg": "{ cat prompts/git-commit.txt; printf '\\n\\n'; git diff --cached; } | gemini | head -n 1 | tr -d '\\r'",
    "commit": "pnpm run -s commit:check && MSG=\"$(pnpm run -s commit:msg)\" && git commit -m \"$MSG\"",
    "generate-types": "wrangler types",
    "deploy": "pnpm build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.7",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.2",
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "^3.6.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@resvg/resvg-wasm": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "vite": "^7"
  },
  "devDependencies": {
    "wrangler": "^4.80.0"
  }
}
