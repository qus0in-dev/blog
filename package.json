{
  "name": "qus0in-dev-blog",
  "type": "module",
  "version": "0.3.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "astro": "astro",
    "preview": "astro preview",
    "dev": "astro dev",
    "generate:og": "node scripts/generate-og.mjs",
    "generate:site-keywords": "node scripts/generate-site-keywords.mjs",
    "build": "pnpm run generate:site-keywords && pnpm run generate:og && astro build",
    "generate-types": "wrangler types",
    "blog:publish": "node scripts/publish-drafts.mjs",
    "blog:deploy": "pnpm build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.7",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.2",
    "@astrojs/rss": "^4.0.12",
    "@astrojs/sitemap": "^3.6.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@resvg/resvg-wasm": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.3",
    "astro-mermaid": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "mermaid": "^11.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
